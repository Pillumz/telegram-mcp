services:
  telegram-mcp:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: telegram-mcp
    env_file:
      - .env
    environment:
      # Optional: Override MCP server settings (defaults shown)
      # MCP_HOST: "0.0.0.0"
      # MCP_PORT: "8080"
      # MCP_PATH_PREFIX: "/mcp"  # Use a secret path for security, e.g., "/mcp/your-secret-token"
    ports:
      - "127.0.0.1:8080:8080"
    restart: unless-stopped
    command: ["python", "main.py"]

  # Optional: OAuth2 proxy for authenticated access
  oauth2-proxy:
    image: quay.io/oauth2-proxy/oauth2-proxy:v7.6.0
    container_name: oauth2-proxy
    ports:
      - "127.0.0.1:4180:4180"
    environment:
      - OAUTH2_PROXY_PROVIDER=github
      - OAUTH2_PROXY_CLIENT_ID=your-github-oauth-client-id
      - OAUTH2_PROXY_CLIENT_SECRET=your-github-oauth-client-secret
      - OAUTH2_PROXY_COOKIE_SECRET=your-random-32-byte-secret
      - OAUTH2_PROXY_COOKIE_SECURE=true
      - OAUTH2_PROXY_UPSTREAM=http://telegram-mcp:8080
      - OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
      - OAUTH2_PROXY_REDIRECT_URL=https://your-domain.com/oauth2/callback
      - OAUTH2_PROXY_EMAIL_DOMAINS=*
      - OAUTH2_PROXY_SCOPE=user:email
      - OAUTH2_PROXY_REVERSE_PROXY=true
      - OAUTH2_PROXY_SET_XAUTHREQUEST=true
      - OAUTH2_PROXY_PASS_ACCESS_TOKEN=true
      - OAUTH2_PROXY_SET_AUTHORIZATION_HEADER=true
      - OAUTH2_PROXY_PASS_AUTHORIZATION_HEADER=true
    restart: unless-stopped
    depends_on:
      - telegram-mcp
